#!/usr/bin/env sh
set -e

die() {
  echo "Error: $*" >&2
  exit 1
}

script_dir="$(dirname "$(readlink -f "$0")")"
src_dir="$(dirname "${script_dir}")"

if [ "${src_dir%/src}" != "${src_dir}" ]; then
  # Running from <repo>/src/bin
  is_source_used="true"

  venv_dir="${src_dir}/../.venv"
  [ -d "${venv_dir}" ] || die "Detected source code environment, but .venv directory is missing. Expected: ${venv_dir}"

  venv_abs="$(readlink -f "${venv_dir}")"
  bin_path="${venv_abs}/bin/python3"
  [ -x "${bin_path}" ] || die ".venv exists, but python3 is missing or not executable. Expected: ${bin_path}"

  case ":${PYTHONPATH}:" in
    *":${src_dir}:"*) ;;
    :) PYTHONPATH="${src_dir}" ;;
    *) PYTHONPATH="${src_dir}:${PYTHONPATH}" ;;
  esac
else
  # Packaged/system install
  is_source_used="false"

  if [ -x "${script_dir}/python3" ]; then
    bin_path="${script_dir}/python3"
  else
    sys_python="$(command -v python3 || true)"
    [ -n "${sys_python}" ] || die "Unable to find 'python3' in PATH."

    bin_path="$(readlink -f "${sys_python}")"
    [ -x "${bin_path}" ] || die "Python executable is not executable at: ${bin_path}"
  fi
fi

exec env _SYSTEST_SOURCE="${is_source_used}" PYTHONPATH="${PYTHONPATH}" "${bin_path}" -m systest "$@"
